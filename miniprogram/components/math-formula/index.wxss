.formula {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.formula-compact {
  gap: 6rpx;
}

.formula-text,
.formula-op,
.formula-paren {
  font-size: 1em;
  line-height: 1;
  color: inherit;
}

.formula-op {
  padding: 0 4rpx;
}

.formula-group {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.formula-group-inner {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.formula-frac {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 72rpx;
}

.formula-frac-top,
.formula-frac-bottom {
  font-size: 1em;
  line-height: 1.1;
  color: inherit;
}

.formula-frac-line {
  width: 100%;
  border-top: 2rpx solid currentColor;
  margin: 6rpx 0;
}

/* Latex渲染样式 */
.formula-latex {
  display: inline-block;
  font-family: serif;
  font-size: 1.1em;
  line-height: 1.5;
  vertical-align: middle;
}


.formula-empty {
  color: #999;
  font-style: italic;
}
