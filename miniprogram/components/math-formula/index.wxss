.formula {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.formula-compact {
  gap: 6rpx;
}

.formula-text,
.formula-op,
.formula-paren,
.formula-script-base {
  font-size: 1em;
  line-height: 1;
  color: inherit;
}

.formula-op {
  padding: 0 4rpx;
}

.formula-group {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.formula-group-inner {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.formula-frac {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 72rpx;
}

.formula-frac-top,
.formula-frac-bottom {
  font-size: 1em;
  line-height: 1.1;
  color: inherit;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 4rpx;
}

.formula-frac-line {
  width: 100%;
  border-top: 2rpx solid currentColor;
  margin: 6rpx 0;
}

/* Latex渲染样式 */
.formula-script {
  display: inline-flex;
  align-items: center;
  gap: 1rpx;
  line-height: 1;
}

.formula-script-stack {
  display: inline-flex;
  flex-direction: column;
  justify-content: center;
  min-width: 12rpx;
  line-height: 0.8;
}

.formula-script-sup,
.formula-script-sub {
  font-size: 0.62em;
  line-height: 0.9;
  color: inherit;
  display: block;
}

.formula-script-sup {
  transform: translateY(-0.28em);
}

.formula-script-sub {
  transform: translateY(0.28em);
}

.formula-script-sup:not(:empty) + .formula-script-sub {
  margin-top: 2rpx;
}


.formula-empty {
  color: #999;
  font-style: italic;
}
