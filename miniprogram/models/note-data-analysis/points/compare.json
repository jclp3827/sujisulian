    "tabs": [
      {
        "id": "knowledge",
        "title": "知识点",
        "blocks": [
          {
            "type": "formula",
            "label": "比较式",
            "content": "基期量 = 现期量 / (1 + 增长率)"
          },
          {
            "type": "rule",
            "title": "判断规则",
            "items": [
              "现期量更大、增长率更小时，基期量必然更大。",
              "现期量更小、增长率更大时，基期量必然更小。",
              "一大一小时，再比较 A / (1 + r)，不要只盯现期量。"
            ]
          },
          {
            "type": "compare",
            "label": "常见结构",
            "left": {
              "title": "可直接判",
              "items": [
                "A 更大且 r 更小",
                "A 更小且 r 更大"
              ]
            },
            "right": {
              "title": "需要估算",
              "items": [
                "A 更大且 r 也更大",
                "A 更小且 r 也更小"
              ]
            }
          },
          {
            "type": "tip",
            "variant": "warning",
            "title": "易错提醒",
            "content": "题目问基期，比较对象是除法结果；增长率越高，分母越大，基期会被压低。"
          }
        ]
      },
      {
