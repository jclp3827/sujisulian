          },
          {
            "type": "compare",
            "label": "层级关系",
            "left": {
              "title": "正确链条",
              "content": "小/中 × 中/大",
              "items": [
                "中层级可以约掉",
                "结果是小/大"
              ]
            },
            "right": {
              "title": "常见误区",
              "content": "方向颠倒或层级错配",
              "items": [
