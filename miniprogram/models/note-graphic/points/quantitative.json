                    "image": {
                      "src": "graphic/point-count-11-tangent-point.png",
                      "title": "切点",
                      "description": "切点示意图，重点看图形内部的线与外框相交或相切的位置。"
                    }
                  }
                ]
              },
              {
                "title": "按位置拆点",
                "summary": "出现圆或框时，看交点在内、上、外的位置。",
                "points": [
                  "内部交点",
                  "圆内交点",
                  "圆上交点",
                  "圆外交点",
