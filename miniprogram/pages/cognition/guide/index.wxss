.guide-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
  padding: 10rpx 0 16rpx;
}

.guide-hero-copy {
  flex: 1;
  min-width: 0;
}

.guide-title {
  font-size: 60rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.1;
  margin-bottom: 14rpx;
}

.guide-subtitle {
  font-size: 26rpx;
  line-height: 1.5;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.guide-underline {
  width: 52rpx;
  height: auto;
}

.guide-hero-art {
  flex: none;
  width: 296rpx;
  height: 300rpx;
}

.guide-section {
  margin-bottom: 24rpx;
}

.guide-section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.guide-copy {
  padding: 28rpx 24rpx;
}

.guide-copy-line {
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--text-secondary);
}

.guide-level-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.guide-level-grid-group {
  margin-bottom: 24rpx;
}

.guide-level-card {
  position: relative;
  min-height: 132rpx;
  padding: 18rpx 12rpx;
  border: 2rpx solid transparent;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  text-align: center;
  transition: transform 160ms ease, box-shadow 160ms ease, border-color 160ms ease, background 160ms ease;
}

.guide-level-card-active {
  background: var(--gradient-primary);
  border-color: transparent;
  box-shadow: var(--shadow-floating);
  transform: translateY(-2rpx);
}

.guide-level-card-active .guide-level-title,
.guide-level-card-active .guide-level-subtitle,
.guide-level-card-active .guide-level-best {
  color: #ffffff;
}

.guide-level-title {
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.32;
  color: var(--text-primary);
}

.guide-level-subtitle {
  font-size: 20rpx;
  line-height: 1.3;
  color: var(--text-tertiary);
}

.guide-level-best {
  font-size: 18rpx;
  line-height: 1.25;
  color: var(--text-tertiary);
  white-space: nowrap;
}

.guide-single-best {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.guide-single-best-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-bottom: 8rpx;
}

.guide-single-best-value {
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 700;
  color: var(--text-primary);
}

.guide-single-action {
  padding: 28rpx 24rpx 0;
}

.guide-start-btn {
  border-radius: 24rpx;
  width: 100%;
}

.bottom-safe-area {
  height: 142rpx;
}

.guide-cta-wrap {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  display: flex;
  justify-content: center;
}

.guide-cta-btn {
  width: 100%;
  min-height: 96rpx;
  border-radius: 24rpx;
}
