.home-page {
  min-height: 100vh;
  background: var(--bg-page-accent);
}

.home-shell {
  min-height: 100vh;
  padding: 20rpx 24rpx calc(148rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
}

.home-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 4rpx;
  padding: 6rpx 2rpx 20rpx;
}

.home-hero-copy {
  flex: 1;
  min-width: 0;
  padding-left: 2rpx;
}

.home-hero-title {
  font-size: 60rpx;
  line-height: 1.1;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.home-hero-desc {
  font-size: 22rpx;
  line-height: 1.45;
  color: var(--text-secondary);
  margin-bottom: 14rpx;
}

.home-hero-underline {
  width: 52rpx;
  height: auto;
}

.home-hero-art {
  flex: none;
  width: 242rpx;
  height: 230rpx;
}

.home-section-card {
  display: grid;
  grid-template-columns: 194rpx minmax(0, 1fr);
  gap: 18rpx;
  min-height: 224rpx;
  padding: 22rpx 18rpx 24rpx;
  margin-bottom: 20rpx;
}

.home-section-thumb {
  width: 194rpx;
  height: 186rpx;
  border-radius: 20rpx;
}

.home-section-main {
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
}

.home-section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.home-section-title {
  font-size: 32rpx;
  line-height: 1.25;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.home-section-accent {
  width: 34rpx;
  height: 8rpx;
  border-radius: 999rpx;
}

.home-card-accent-blue {
  background: var(--color-primary-500);
}

.home-card-accent-green {
  background: var(--color-green-500);
}

.home-card-accent-purple {
  background: var(--color-purple-500);
}

.home-section-arrow {
  background: rgba(255, 255, 255, 0.72);
}

.home-section-desc {
  font-size: 21rpx;
  line-height: 1.55;
  color: var(--text-secondary);
  margin-bottom: 28rpx;
}

.home-progress-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: 4rpx;
  margin-bottom: 12rpx;
}

.home-progress-text,
.home-progress-recent {
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.3;
  color: var(--text-tertiary);
  white-space: nowrap;
}

.home-progress-text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
}

.home-progress-recent {
  flex: none;
}

.home-progress-track {
  width: 100%;
  height: 12rpx;
  border-radius: 999rpx;
  background: var(--border-subtle);
  overflow: hidden;
}

.home-progress-fill {
  height: 100%;
  min-width: 0;
  border-radius: inherit;
  transition: width 200ms ease;
}

.home-week {
  padding: 24rpx 22rpx 20rpx;
  margin: 2rpx 0 20rpx;
}

.home-week-head {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  margin-bottom: 18rpx;
}

.home-week-title {
  font-size: 28rpx;
  line-height: 1.3;
  font-weight: 700;
  color: var(--text-primary);
}

.home-week-days {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 10rpx;
}

.home-week-day {
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
}

.home-week-bar-wrap {
  width: 100%;
  height: 62rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  margin-bottom: 8rpx;
}

.home-week-bar {
  width: 22rpx;
  min-height: 12rpx;
  border-radius: 999rpx;
  background: var(--border-subtle);
}

.home-week-bar-active {
  background: var(--gradient-primary);
}

.home-week-count {
  min-height: 28rpx;
  font-size: 22rpx;
  line-height: 1.25;
  font-weight: 700;
  color: var(--text-primary);
}

.home-week-label {
  font-size: 20rpx;
  line-height: 1.3;
  color: var(--text-tertiary);
}

.home-footer {
  margin-top: auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 46rpx 0 24rpx;
}

.home-footer-line {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
}

.home-footer-icon {
  width: 28rpx;
  height: 28rpx;
}

.home-footer-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
  text-align: center;
}

.home-footer-author {
  font-size: 22rpx;
  line-height: 1.4;
  color: var(--text-tertiary);
  text-align: center;
}
