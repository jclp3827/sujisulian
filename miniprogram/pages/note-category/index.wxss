.note-category-page {
  min-height: 100vh;
  background: var(--bg-page-accent);
}

.note-category-shell {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
}

.note-category-hero {
  padding: 4rpx 2rpx 26rpx;
}

.note-category-kicker {
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 700;
  color: var(--color-green-500);
  margin-bottom: 8rpx;
}

.note-category-title {
  font-size: 46rpx;
  line-height: 1.2;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.note-category-desc {
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--text-secondary);
}

.note-point-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.note-point-card {
  padding: 24rpx;
}

.note-point-main {
  min-width: 0;
}

.note-point-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.note-point-type {
  font-size: 22rpx;
  line-height: 1.3;
  font-weight: 700;
  color: var(--color-primary-500);
  margin-bottom: 6rpx;
}

.note-point-title {
  font-size: 34rpx;
  line-height: 1.25;
  font-weight: 700;
  color: var(--text-primary);
}

.note-point-arrow {
  flex: none;
  width: 36rpx;
  text-align: center;
  font-size: 46rpx;
  line-height: 1;
  font-weight: 300;
  color: var(--text-tertiary);
}

.note-point-formula {
  padding: 18rpx 20rpx;
  border-radius: var(--radius-sm);
  background: var(--bg-soft-blue);
  font-size: 26rpx;
  line-height: 1.5;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 14rpx;
}

.note-point-scene {
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--text-secondary);
}
