.note-detail-page {
  min-height: 100vh;
  background: var(--bg-page-accent);
}

.note-detail-shell {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
}

.note-detail-hero {
  padding: 4rpx 2rpx 24rpx;
}

.note-detail-kicker {
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 700;
  color: var(--color-green-500);
  margin-bottom: 8rpx;
}

.note-detail-title {
  font-size: 48rpx;
  line-height: 1.18;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.note-detail-desc {
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--text-secondary);
}

.note-detail-tabs {
  margin-bottom: 20rpx;
}

.note-detail-tab {
  flex: 1;
  min-height: 58rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 23rpx;
  font-weight: 700;
  color: var(--text-secondary);
}

.note-detail-tab-active {
  background: var(--bg-card);
  color: var(--text-primary);
  box-shadow: var(--shadow-active);
}

.note-detail-section {
  padding: 26rpx 24rpx;
}

.note-block {
  margin-bottom: 24rpx;
}

.note-block:last-child {
  margin-bottom: 0;
}

.note-section-label {
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 700;
  color: var(--text-primary);
  margin: 2rpx 0 14rpx;
}

.note-formula-box {
  padding: 20rpx;
  border-radius: var(--radius-sm);
  background: var(--bg-soft-blue);
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 700;
  color: var(--text-primary);
}

.note-formula-box .formula {
  justify-content: flex-start;
}

.note-step-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.note-step-item {
  display: grid;
  grid-template-columns: 44rpx minmax(0, 1fr);
  column-gap: 14rpx;
  align-items: start;
}

.note-step-index {
  width: 44rpx;
  height: 44rpx;
  border-radius: 999rpx;
  background: var(--color-primary-100);
  color: var(--color-primary-500);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
}

.note-step-text,
.note-tip-text,
.note-example-stem,
.note-example-analysis,
.note-practice-desc,
.note-check-text,
.note-compare-content,
.note-compare-item,
.note-table-cell {
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--text-secondary);
}

.note-plain-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.note-plain-item {
  min-height: 58rpx;
  border-radius: var(--radius-sm);
  background: var(--bg-soft-blue);
  display: flex;
  align-items: center;
  padding: 10rpx 16rpx;
  font-size: 25rpx;
  line-height: 1.35;
  font-weight: 700;
  color: var(--text-primary);
}

.note-check-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.note-check-item {
  display: grid;
  grid-template-columns: 18rpx minmax(0, 1fr);
  column-gap: 14rpx;
  align-items: start;
  padding: 16rpx 18rpx;
  border-radius: var(--radius-sm);
  background: var(--bg-soft-blue);
}

.note-check-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: var(--color-primary-500);
  margin-top: 16rpx;
}

.note-compare-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.note-compare-card {
  min-width: 0;
  padding: 18rpx;
  border-radius: var(--radius-sm);
  background: var(--bg-soft-blue);
}

.note-compare-card-accent {
  background: var(--bg-soft-green);
}

.note-compare-title {
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 10rpx;
}

.note-compare-content {
  font-weight: 700;
  color: var(--text-primary);
}

.note-compare-item {
  margin-top: 8rpx;
}

.note-table {
  overflow: hidden;
  border-radius: var(--radius-sm);
  background: var(--bg-soft-blue);
}

.note-table-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  border-top: 2rpx solid rgba(76, 112, 146, 0.12);
}

.note-table-row:first-child {
  border-top: 0;
}

.note-table-head {
  background: rgba(255, 255, 255, 0.62);
}

.note-table-head .note-table-cell {
  font-weight: 700;
  color: var(--text-primary);
}

.note-table-cell {
  min-width: 0;
  padding: 16rpx 18rpx;
  border-left: 2rpx solid rgba(76, 112, 146, 0.12);
}

.note-table-cell:first-child {
  border-left: 0;
}

.note-table-compact .note-table-cell {
  padding: 12rpx 10rpx;
  font-size: 24rpx;
  line-height: 1.35;
  text-align: center;
}

.note-table-compact .note-table-cell:nth-child(2),
.note-table-compact .note-table-cell:nth-child(4) {
  color: #1f6f78;
  background: rgba(31, 111, 120, 0.08);
  font-weight: 700;
}

.note-mind-map {
  padding: 22rpx;
  border-radius: var(--radius-sm);
  background: linear-gradient(180deg, #f8fbff 0%, #f3f7f2 100%);
}

.note-mind-root {
  padding: 22rpx 24rpx;
  border-radius: var(--radius-sm);
  background: #ffffff;
  border: 2rpx solid rgba(47, 107, 255, 0.14);
}

.note-mind-root-title {
  font-size: 34rpx;
  line-height: 1.35;
  font-weight: 800;
  color: var(--text-primary);
}

.note-mind-root-summary {
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.55;
  color: var(--text-secondary);
}

.note-mind-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.note-mind-action {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(47, 107, 255, 0.08);
  font-size: 23rpx;
  line-height: 1.35;
  color: var(--color-primary-600);
}

.note-mind-branches {
  margin-top: 22rpx;
}

.note-mind-branch {
  position: relative;
  padding-left: 24rpx;
  margin-top: 20rpx;
  border-left: 4rpx solid rgba(47, 107, 255, 0.22);
}

.note-mind-branch:first-child {
  margin-top: 0;
}

.note-mind-node {
  position: relative;
  padding: 18rpx 20rpx;
  border-radius: var(--radius-sm);
  background: #ffffff;
  border: 2rpx solid rgba(76, 112, 146, 0.12);
}

.note-mind-node::before {
  content: "";
  position: absolute;
  left: -34rpx;
  top: 28rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: var(--color-primary-500);
}

.note-mind-node-level-1 {
  background: #ffffff;
}

.note-mind-node-level-2 {
  background: #f8fafc;
}

.note-mind-node-level-3 {
  background: #fffdf7;
}

.note-mind-node-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.note-mind-node-toggleable {
  cursor: pointer;
}

.note-mind-node-title {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.35;
  font-weight: 800;
  color: var(--text-primary);
}

.note-mind-toggle {
  flex-shrink: 0;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(76, 112, 146, 0.1);
  font-size: 22rpx;
  line-height: 1.35;
  color: var(--text-secondary);
}

.note-mind-node-summary {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--text-secondary);
}

.note-mind-point-list {
  margin-top: 12rpx;
}

.note-mind-point {
  position: relative;
  padding-left: 20rpx;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--text-secondary);
}

.note-mind-point::before {
  content: "";
  position: absolute;
  left: 0;
  top: 15rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--color-green-500);
}

.note-mind-children {
  margin-top: 14rpx;
  padding-left: 22rpx;
  border-left: 2rpx solid rgba(76, 112, 146, 0.16);
}

.note-mind-children-deep {
  border-left-style: dashed;
}

.note-mind-child {
  margin-top: 14rpx;
}

.note-mind-child:first-child {
  margin-top: 0;
}

.note-mind-image-wrap {
  overflow: hidden;
  margin-top: 16rpx;
  border-radius: var(--radius-sm);
  background: #ffffff;
  border: 2rpx solid rgba(76, 112, 146, 0.12);
}

.note-mind-image-title {
  padding: 14rpx 16rpx 0;
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 700;
  color: var(--text-primary);
}

.note-mind-image {
  display: block;
  width: 100%;
  margin-top: 12rpx;
}

.note-mind-image-desc {
  padding: 12rpx 16rpx 16rpx;
  font-size: 22rpx;
  line-height: 1.45;
  color: var(--text-muted);
}

.note-image-note {
  overflow: hidden;
  border-radius: var(--radius-sm);
  background: var(--bg-soft-blue);
}

.note-image {
  display: block;
  width: 100%;
}

.note-image-placeholder {
  min-height: 220rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 28rpx;
  border: 2rpx dashed rgba(47, 107, 255, 0.22);
  border-radius: var(--radius-sm);
  background: rgba(255, 255, 255, 0.5);
}

.note-image-title {
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  text-align: center;
}

.note-image-status {
  min-width: 104rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: var(--bg-card);
  font-size: 22rpx;
  line-height: 1.25;
  font-weight: 700;
  color: var(--color-primary-500);
  text-align: center;
}

.note-image-desc {
  padding: 18rpx 20rpx;
  font-size: 25rpx;
  line-height: 1.55;
  color: var(--text-secondary);
}

.note-tip-box,
.note-warning-box {
  padding: 18rpx 20rpx;
  border-radius: var(--radius-sm);
}

.note-tip-box {
  background: var(--bg-soft-green);
}

.note-warning-box {
  background: #fff7ed;
}

.note-tip-title {
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.note-example-stem {
  padding: 20rpx;
  border-radius: var(--radius-sm);
  background: var(--bg-soft-blue);
  margin-bottom: 24rpx;
}

.note-example-analysis {
  padding: 20rpx;
  border-radius: var(--radius-sm);
  background: var(--bg-soft-green);
}

.note-example-image-note {
  overflow: hidden;
  margin-top: 16rpx;
  border-radius: var(--radius-sm);
  background: var(--bg-soft-blue);
}

.note-example-source {
  display: inline-block;
  align-self: flex-start;
  padding: 6rpx 16rpx;
  margin-bottom: 12rpx;
  border-radius: 999rpx;
  background: var(--bg-card);
  color: var(--color-green-500);
  font-size: 22rpx;
  line-height: 1.3;
  font-weight: 700;
  box-shadow: var(--shadow-active);
}

.note-example-options {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.note-example-option {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 14rpx 16rpx;
  border-radius: var(--radius-sm);
  background: var(--bg-soft-blue);
  font-size: 26rpx;
  line-height: 1.55;
  color: var(--text-primary);
}

.note-example-option-key {
  flex-shrink: 0;
  min-width: 36rpx;
  height: 36rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-card);
  color: var(--color-green-500);
  font-size: 24rpx;
  font-weight: 700;
  box-shadow: var(--shadow-active);
}

.note-example-option-text {
  flex: 1;
}

.note-example-option-answer {
  background: var(--bg-soft-green);
}

.note-example-option-answer .note-example-option-key {
  background: var(--color-green-500);
  color: var(--text-inverse);
}

.note-example-answer-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
  padding: 12rpx 16rpx;
  border-radius: var(--radius-sm);
  background: var(--bg-card);
  box-shadow: var(--shadow-active);
}

.note-example-answer-label {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--color-green-500);
}

.note-example-answer-value {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.note-practice-title {
  font-size: 36rpx;
  line-height: 1.25;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.note-practice-action {
  margin-top: 28rpx;
  min-height: 84rpx;
  font-size: 30rpx;
}

.note-load-more {
  margin-top: 24rpx;
  padding: 20rpx;
  text-align: center;
  border-radius: var(--radius-sm);
  background: var(--bg-soft-blue);
}

.note-load-more-text {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--color-primary-500);
}
