.note-page {
  min-height: 100vh;
  background: var(--bg-page-accent);
}

.note-shell {
  min-height: 100vh;
  padding: 28rpx 24rpx 40rpx;
}

.note-hero {
  padding: 8rpx 2rpx 30rpx;
}

.note-hero-title {
  font-size: 56rpx;
  line-height: 1.15;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 14rpx;
}

.note-hero-desc {
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--text-secondary);
}

.note-section-title {
  font-size: 28rpx;
  line-height: 1.3;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 18rpx;
}

.note-module-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.note-module-card {
  min-height: 164rpx;
  padding: 24rpx 22rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.note-module-ready {
  border-color: rgba(51, 196, 122, 0.16);
}

.note-module-pending {
  opacity: 0.72;
}

.note-module-mark {
  flex: none;
  width: 18rpx;
  height: 92rpx;
  border-radius: 999rpx;
  background: var(--border-subtle);
}

.note-module-mark-ready {
  background: var(--color-green-500);
}

.note-module-main {
  flex: 1;
  min-width: 0;
}

.note-module-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.note-module-title {
  min-width: 0;
  font-size: 32rpx;
  line-height: 1.25;
  font-weight: 700;
  color: var(--text-primary);
}

.note-module-status {
  flex: none;
  min-width: 96rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: var(--bg-soft-blue);
  color: var(--text-tertiary);
  font-size: 22rpx;
  line-height: 1.2;
  text-align: center;
}

.note-status-ready {
  background: var(--bg-soft-green);
  color: var(--color-green-500);
}

.note-module-keywords {
  font-size: 24rpx;
  line-height: 1.45;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.note-module-desc {
  font-size: 22rpx;
  line-height: 1.45;
  color: var(--text-tertiary);
}

.note-module-arrow {
  flex: none;
  width: 44rpx;
  text-align: center;
  font-size: 50rpx;
  line-height: 1;
  font-weight: 300;
  color: var(--text-tertiary);
}
