.note-map-page {
  min-height: 100vh;
  background: var(--bg-page-accent);
}

.note-map-shell {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
}

.note-map-hero {
  padding: 4rpx 2rpx 28rpx;
}

.note-map-kicker {
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 700;
  color: var(--color-green-500);
  margin-bottom: 8rpx;
}

.note-map-title {
  font-size: 48rpx;
  line-height: 1.18;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.note-map-desc {
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--text-secondary);
}

.note-path {
  display: flex;
  flex-direction: column;
}

.note-path-item {
  display: grid;
  grid-template-columns: 64rpx minmax(0, 1fr);
  column-gap: 10rpx;
  min-height: 148rpx;
}

.note-path-rail {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.note-path-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 999rpx;
  background: var(--bg-card);
  border: 2rpx solid var(--border-subtle);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  line-height: 1;
  font-weight: 700;
  color: var(--text-tertiary);
  z-index: 1;
}

.note-path-dot-ready {
  background: var(--color-green-500);
  border-color: var(--color-green-500);
  color: #ffffff;
}

.note-path-line {
  width: 4rpx;
  flex: 1;
  min-height: 96rpx;
  background: var(--border-subtle);
}

.note-path-card {
  min-height: 116rpx;
  padding: 22rpx 20rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.note-path-card-ready {
  border-color: rgba(51, 196, 122, 0.16);
}

.note-path-card-pending {
  opacity: 0.72;
}

.note-path-main {
  flex: 1;
  min-width: 0;
}

.note-path-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-bottom: 8rpx;
}

.note-path-title {
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 700;
  color: var(--text-primary);
}

.note-path-status {
  flex: none;
  min-width: 90rpx;
  padding: 7rpx 12rpx;
  border-radius: 999rpx;
  background: var(--bg-soft-blue);
  color: var(--text-tertiary);
  font-size: 21rpx;
  line-height: 1.2;
  text-align: center;
}

.note-status-ready {
  background: var(--bg-soft-green);
  color: var(--color-green-500);
}

.note-path-subtitle {
  font-size: 24rpx;
  line-height: 1.45;
  color: var(--text-secondary);
  margin-bottom: 6rpx;
}

.note-path-meta {
  font-size: 22rpx;
  line-height: 1.35;
  color: var(--text-tertiary);
}

.note-path-arrow {
  flex: none;
  width: 36rpx;
  text-align: center;
  font-size: 46rpx;
  line-height: 1;
  font-weight: 300;
  color: var(--text-tertiary);
}
