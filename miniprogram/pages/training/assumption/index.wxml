<scroll-view class="page-scroll" scroll-y="true" enhanced="true" show-scrollbar="false" scroll-into-view="{{scrollInto}}" scroll-with-animation="true">
  <view class="page-shell page-pad">
    <view class="session-head">
      <view class="session-title">分配树训练</view>
      <view class="session-meta-row">
        <view class="session-meta-card surface-card">
          <view class="session-meta-label">第</view>
          <view class="session-meta-value">{{index + 1}} / {{total}}</view>
        </view>
        <view class="session-meta-card surface-card">
          <view class="session-meta-label">用时</view>
          <view class="session-meta-value">{{elapsedText}}</view>
        </view>
        <view class="session-meta-card surface-card">
          <view class="session-meta-label">进度</view>
          <view class="session-meta-value">{{filledCount}} / {{totalFields}}</view>
        </view>
      </view>
      <view class="session-progress-track">
        <view class="session-progress-fill" style="width: {{progressPercent}}%;"></view>
      </view>
    </view>

   <view class="question-board surface-card" wx:if="{{current}}">
     <view class="question-top">
       <view class="question-no">第 {{index + 1}} 题</view>
       <view class="pen-entry" bindtap="toggleHandwriting">手写板</view>
     </view>
     <!-- 已知条件 -->
     <view class="es-conditions">
        <view class="es-condition-cell">
          <text class="es-condition-label">B（现期量）</text>
          <text class="es-condition-value">{{current.B}}</text>
        </view>
        <view class="es-condition-divider"></view>
        <view class="es-condition-cell">
          <text class="es-condition-label">R(增长率)</text>
          <text class="es-condition-value">{{current.rate > 0 ? '+' : ''}}{{current.rate}}%</text>
        </view>
      </view>

      <!-- 分配树 -->
      <view class="aa-tree">
        <view class="aa-fork aa-fork-3 aa-fork-root">
          <view class="aa-line aa-line-lt"></view>
          <view class="aa-line aa-line-ct"></view>
          <view class="aa-line aa-line-rt"></view>
        </view>

        <!-- 第1层 -->
        <view class="aa-row aa-row-triple">
          <view id="field-levels-0-a" class="aa-node aa-role-base aa-status-{{levels[0].aStatus}} {{levels[0].aActive ? 'aa-input-active' : ''}}" data-field="levels.0.a" bindtap="selectField">
            <view class="aa-node-label"><text>A</text><text class="aa-label-sub">1</text></view>
            <text class="aa-node-value {{levels[0].a ? '' : 'aa-node-value-placeholder'}}">{{levels[0].a || '填'}}</text>
          </view>
          <view id="field-levels-1-b" class="aa-node aa-node-shifted aa-role-current aa-status-{{levels[1].bStatus}} {{levels[1].bActive ? 'aa-input-active' : ''}}" data-field="levels.1.b" bindtap="selectField">
            <view class="aa-node-label"><text>B</text><text class="aa-label-sub">1</text></view>
            <text class="aa-node-value {{levels[1].b ? '' : 'aa-node-value-placeholder'}}">{{levels[1].b || '填'}}</text>
          </view>
          <view id="field-levels-0-x" class="aa-node aa-role-growth aa-status-{{levels[0].xStatus}} {{levels[0].xActive ? 'aa-input-active' : ''}}" data-field="levels.0.x" bindtap="selectField">
            <view class="aa-node-label"><text>X</text><text class="aa-label-sub">1</text></view>
            <text class="aa-node-value {{levels[0].x ? '' : 'aa-node-value-placeholder'}}">{{levels[0].x || '填'}}</text>
          </view>
        </view>

        <view class="aa-branch">
          <view class="aa-branch-stem"></view>
          <view class="aa-fork aa-fork-3">
            <view class="aa-line aa-line-lt"></view>
            <view class="aa-line aa-line-ct"></view>
            <view class="aa-line aa-line-rt"></view>
          </view>
        </view>

        <!-- 第2层 -->
        <view class="aa-row aa-row-triple">
          <view id="field-levels-1-a" class="aa-node aa-role-base aa-status-{{levels[1].aStatus}} {{levels[1].aActive ? 'aa-input-active' : ''}}" data-field="levels.1.a" bindtap="selectField">
            <view class="aa-node-label"><text>A</text><text class="aa-label-sub">2</text></view>
            <text class="aa-node-value {{levels[1].a ? '' : 'aa-node-value-placeholder'}}">{{levels[1].a || '填'}}</text>
          </view>
          <view id="field-levels-2-b" class="aa-node aa-node-shifted aa-role-current aa-status-{{levels[2].bStatus}} {{levels[2].bActive ? 'aa-input-active' : ''}}" data-field="levels.2.b" bindtap="selectField">
            <view class="aa-node-label"><text>B</text><text class="aa-label-sub">2</text></view>
            <text class="aa-node-value {{levels[2].b ? '' : 'aa-node-value-placeholder'}}">{{levels[2].b || '填'}}</text>
          </view>
          <view id="field-levels-1-x" class="aa-node aa-role-growth aa-status-{{levels[1].xStatus}} {{levels[1].xActive ? 'aa-input-active' : ''}}" data-field="levels.1.x" bindtap="selectField">
            <view class="aa-node-label"><text>X</text><text class="aa-label-sub">2</text></view>
            <text class="aa-node-value {{levels[1].x ? '' : 'aa-node-value-placeholder'}}">{{levels[1].x || '填'}}</text>
          </view>
        </view>

        <view class="aa-branch">
          <view class="aa-branch-stem"></view>
          <view class="aa-fork aa-fork-2">
            <view class="aa-line aa-line-lt"></view>
            <view class="aa-line aa-line-rt"></view>
          </view>
        </view>

        <!-- 第3层 -->
        <view class="aa-row aa-row-triple">
          <view id="field-levels-2-a" class="aa-node aa-role-base aa-status-{{levels[2].aStatus}} {{levels[2].aActive ? 'aa-input-active' : ''}}" data-field="levels.2.a" bindtap="selectField">
            <view class="aa-node-label"><text>A</text><text class="aa-label-sub">3</text></view>
            <text class="aa-node-value {{levels[2].a ? '' : 'aa-node-value-placeholder'}}">{{levels[2].a || '填'}}</text>
          </view>
          <view class="aa-placeholder"></view>
          <view id="field-levels-2-x" class="aa-node aa-role-growth aa-status-{{levels[2].xStatus}} {{levels[2].xActive ? 'aa-input-active' : ''}}" data-field="levels.2.x" bindtap="selectField">
            <view class="aa-node-label"><text>X</text><text class="aa-label-sub">3</text></view>
            <text class="aa-node-value {{levels[2].x ? '' : 'aa-node-value-placeholder'}}">{{levels[2].x || '填'}}</text>
          </view>
        </view>
      </view>

      <view class="aa-tree-hint">先填写A和X,我会自动核对合计,无需填完所有空</view>

      <!-- 结果参考 -->
      <block wx:if="{{submitted}}">
        <view class="es-result-section {{correct ? 'es-tone-pass' : 'es-tone-fail'}}">
          <view class="es-compact-result-row">
            <text class="es-section-label">你的结果</text>
            <text class="es-result-item">A = {{resultA}}</text>
            <text class="es-result-item">X = {{resultX}}</text>
          </view>
        </view>
        <view class="es-reference-section">
          <view class="es-compact-result-row">
            <text class="es-section-label">标准参考</text>
            <text class="es-result-item">A = {{referenceA}}</text>
            <text class="es-result-item">X = {{referenceX}}</text>
          </view>
        </view>
      </block>

      <!-- 反馈 -->
      <view wx:if="{{submitted && feedbackText}}" class="aa-feedback {{correct ? 'aa-feedback-pass' : 'aa-feedback-review'}}">
        <text class="aa-feedback-sub">{{feedbackText}}</text>
      </view>

      <!-- 准确度 -->
      <view id="feedbackAnchor" wx:if="{{submitted}}" class="es-accuracy-row">
        <text class="es-accuracy-label">准确度</text>
        <text class="es-accuracy-value {{correct ? 'es-accuracy-pass' : 'es-accuracy-fail'}}">{{accuracy}}%</text>
      </view>
      <view wx:if="{{submitted}}" class="es-accuracy-bars">
        <view wx:for="{{accuracyBars}}" wx:key="index" class="es-accuracy-bar {{item ? (correct ? 'es-accuracy-bar-pass' : 'es-accuracy-bar-fail') : 'es-accuracy-bar-off'}}"></view>
      </view>
    </view>
  </view>
</scroll-view>

<!-- 底部键盘区（普通流定位，不再fixed） -->
 <view class="aa-keyboard surface-card">
   <view class="keypad">
    <view class="keypad-grid keypad-grid-base">
      <block wx:for="{{['7','8','9','4','5','6','1','2','3','0','.','-']}}" wx:for-item="key" wx:key="*this">
        <view hover-class="keypad-key-pressed" class="keypad-key keypad-key-base" data-key="{{key}}" bindtap="handleKeyTap">{{key}}</view>
      </block>
      <view hover-class="keypad-key-pressed" class="keypad-key keypad-key-base keypad-key-light" data-key="clear" bindtap="handleKeyTap">清空</view>
      <view hover-class="keypad-key-pressed" class="keypad-key keypad-key-base keypad-key-light" data-key="delete" bindtap="handleKeyTap">退格</view>
    </view>
  </view>
  <view class="aa-action-row">
    <button hover-class="btn-pressed" class="btn-base btn-primary btn-large" bindtap="submitAnswer">确认答案</button>
    <button wx:if="{{submitted}}" hover-class="btn-pressed" class="btn-base btn-secondary btn-large" bindtap="nextQuestion">下一题</button>
  </view>

  <!-- 手写板 -->
  <view wx:if="{{handwritingVisible}}" class="handwriting-overlay" catchtap="noop">
    <view class="handwriting-sheet sheet-drawer" catchtap="noop">
      <canvas
        canvas-id="handwritingCanvas"
        class="handwriting-canvas sheet-drawer-canvas"
        disable-scroll="{{true}}"
        catchtouchstart="startHandwriting"
        catchtouchmove="moveHandwriting"
        catchtouchend="endHandwriting"
        catchtouchcancel="endHandwriting"
      />
      <view class="handwriting-toolbar floating-bar" catchtap="noop">
        <view
          class="handwriting-tool {{handwritingTool === 'erase' ? 'handwriting-tool-active handwriting-tool-danger' : ''}}"
          bindtap="toggleHandwritingTool"
          data-tool="erase"
        >
          橡皮擦
        </view>
        <view class="handwriting-tool" bindtap="clearHandwriting">清空</view>
        <view class="handwriting-tool handwriting-tool-primary" bindtap="toggleHandwriting">关闭</view>
      </view>
    </view>
  </view>
</view>
