/* ===== 页面滚动 ===== */
page {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.page-scroll {
  flex: 1 1 auto;
  min-height: 0;
  overflow-y: auto;
  box-sizing: border-box;
}

/* ===== 已知条件 ===== */
.aa-conditions {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.aa-pill {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  box-sizing: border-box;
}

.aa-pill-blue {
  background: var(--bg-soft-blue);
  border: 1rpx solid var(--border-soft);
}

.aa-pill-orange {
  background: var(--bg-soft-orange);
  border: 1rpx solid var(--border-orange);
}

.aa-pill-label {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--text-secondary);
}

.aa-pill-value {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text-primary);
}

/* ===== 已知条件卡片（复用拆分估算样式） ===== */
.es-conditions {
  display: flex;
  align-items: center;
  margin-bottom: 0;
  background: #ffffff;
  border: 1rpx solid rgba(47, 107, 255, 0.18);
  border-radius: var(--radius-sm);
  overflow: hidden;
}

.es-condition-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx 0;
}

.es-condition-divider {
  width: 1rpx;
  align-self: stretch;
  background: var(--border-subtle);
}

.es-condition-label {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.es-condition-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

/* ===== 准确度 ===== */
.es-accuracy-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
  padding: 0 8rpx;
}

.es-accuracy-label {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-secondary);
}

.es-accuracy-value {
  font-size: 36rpx;
  font-weight: 800;
}

.es-accuracy-pass {
  color: var(--color-green-700);
}

.es-accuracy-fail {
  color: var(--color-orange-700);
}

.es-accuracy-bars {
  display: flex;
  gap: 8rpx;
  margin-top: 10rpx;
  padding: 0 8rpx;
}

.es-accuracy-bar {
  flex: 1;
  height: 12rpx;
  border-radius: 6rpx;
  transition: background 0.3s;
}

.es-accuracy-bar-pass {
  background: var(--color-green-500);
}

.es-accuracy-bar-fail {
  background: var(--color-warning);
}

.es-accuracy-bar-off {
  background: var(--border-subtle);
}

/* ===== 分配树 ===== */
.aa-tree {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 0 14rpx;
}

.aa-row {
  display: flex;
  align-items: flex-start;
  width: 100%;
}

.aa-row-center {
  justify-content: center;
}

.aa-row-triple {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  column-gap: 20rpx;
  row-gap: 0;
}

.aa-node {
  position: relative;
  border-radius: 16rpx;
  border: 2rpx solid rgba(148, 163, 184, 0.18);
  padding: 12rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  min-height: 76rpx;
  min-width: 0;
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.05);
  transition: border-color 120ms ease, box-shadow 120ms ease, transform 120ms ease;
}

.aa-node-readonly {
  opacity: 0.85;
  box-shadow: none;
  border: 2rpx solid var(--border-subtle);
}

.aa-node-readonly .aa-node-value {
  background: transparent;
}

.aa-placeholder {
  min-height: 1rpx;
}

.aa-node-label {
  flex: none;
  min-width: 32rpx;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1;
  color: currentColor;
  text-align: center;
  opacity: 0.8;
}

.aa-label-sub {
  display: inline-block;
  margin-left: 1rpx;
  font-size: 15rpx;
  line-height: 1;
  vertical-align: sub;
}

.aa-node-value {
  flex: 1;
  width: auto;
  min-width: 0;
  min-height: 46rpx;
  padding: 7rpx 6rpx;
  box-sizing: border-box;
  border-radius: 10rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(148, 163, 184, 0.12);
  font-size: 28rpx;
  line-height: 1.2;
  font-weight: 800;
  color: var(--text-primary);
  text-align: center;
  word-break: break-all;
}

.aa-node-value-placeholder {
  font-size: 24rpx;
  color: var(--text-tertiary);
  font-weight: 700;
}

/* 角色底色 */
.aa-role-base {
  background: #edf9f2;
  color: var(--color-green-700);
  border-color: rgba(51, 196, 122, 0.24);
}

.aa-role-current {
  background: #eef5ff;
  color: var(--color-primary-600);
  border-color: rgba(47, 107, 255, 0.22);
}

.aa-role-growth {
  background: #f5f2ff;
  color: #6d4fe0;
  border-color: rgba(124, 92, 255, 0.24);
}

/* ===== 连接线 ===== */
.aa-fork {
  position: relative;
  width: 100%;
  height: 69rpx;
  display: flex;
  justify-content: center;
  overflow: visible;
}

.aa-line {
  position: absolute;
  top: 0;
  left: 50%;
  width: 3rpx;
  border-radius: 999rpx;
  background: rgba(47, 107, 255, 0.54);
  transform-origin: top center;
}

.aa-line::after {
  content: "";
  position: absolute;
  bottom: -6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 4rpx solid transparent;
  border-right: 4rpx solid transparent;
  border-top: 6rpx solid rgba(47, 107, 255, 0.68);
}

.aa-line-ct {
  height: calc(100% + 23rpx);
  transform: translateX(-50%);
}

.aa-line-lt,
.aa-line-rt {
  height: 230rpx;
}

.aa-line-lt {
  transform: translateX(-50%) rotate(-75deg);
}

.aa-line-rt {
  transform: translateX(-50%) rotate(75deg);
}

.aa-branch {
  position: relative;
  width: 100%;
  height: 65rpx;
  display: flex;
  justify-content: center;
}

.aa-branch-stem {
  position: absolute;
  top: 0;
  left: 50%;
  width: 3rpx;
  height: 100%;
  border-radius: 999rpx;
  background: rgba(47, 107, 255, 0.54);
  transform: translateX(-50%);
}

.aa-fork-2 .aa-line-ct {
  display: none;
}

.aa-node-shifted {
  margin-top: 23rpx;
}

/* ===== 选中 / 正确 / 错误 ===== */
.aa-role-current.aa-input-active {
  border-color: var(--color-primary-500);
  color: var(--color-primary-600);
  box-shadow: 0 0 0 4rpx rgba(47, 107, 255, 0.16), 0 12rpx 28rpx rgba(47, 107, 255, 0.12);
  transform: translateY(-2rpx);
}

.aa-node-shifted.aa-input-active {
  transform: translateY(-2rpx);
}

.aa-role-current.aa-input-active .aa-node-value {
  border-color: rgba(47, 107, 255, 0.34);
  background: var(--color-primary-50);
}

.aa-role-base.aa-input-active {
  border-color: #1f8f4d;
  color: #1f7a43;
  box-shadow: 0 0 0 4rpx rgba(51, 196, 122, 0.18), 0 12rpx 28rpx rgba(37, 132, 74, 0.12);
  transform: translateY(-2rpx);
}

.aa-role-base.aa-input-active .aa-node-value {
  border-color: rgba(31, 143, 77, 0.36);
  background: #ecfdf3;
}

.aa-role-growth.aa-input-active {
  border-color: #6d4fe0;
  color: #5b3fd1;
  box-shadow: 0 0 0 4rpx rgba(124, 92, 255, 0.18), 0 12rpx 28rpx rgba(124, 92, 255, 0.14);
  transform: translateY(-2rpx);
}

.aa-role-growth.aa-input-active .aa-node-value {
  border-color: rgba(109, 79, 224, 0.36);
  background: #f5f2ff;
}

.aa-status-pass {
  border-color: rgba(37, 132, 74, 0.55);
}

.aa-status-fail {
  border-color: rgba(199, 55, 55, 0.62);
}

.aa-tree-hint {
  margin-top: 14rpx;
  padding: 10rpx 16rpx;
  border-radius: 12rpx;
  background: rgba(47, 107, 255, 0.08);
  border: 1rpx solid rgba(47, 107, 255, 0.16);
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.5;
  color: var(--color-primary-600);
  text-align: center;
}

/* ===== 结果区域 ===== */
.es-result-section,
.es-reference-section {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  border-radius: var(--radius-sm);
  background: var(--bg-soft-blue);
  border: 1rpx solid var(--border-soft);
}

.es-reference-section {
  margin-top: 10rpx;
  background: var(--bg-soft-green);
  border: 1rpx solid rgba(37, 132, 74, 0.24);
}

.es-tone-pass {
  background: var(--bg-soft-green);
  border: 1rpx solid rgba(37, 132, 74, 0.24);
}

.es-tone-fail {
  background: var(--bg-soft-orange);
  border: 1rpx solid rgba(185, 91, 18, 0.22);
}

.es-compact-result-row {
  display: grid;
  grid-template-columns: 112rpx minmax(0, 1fr) minmax(0, 1fr);
  align-items: center;
  gap: 12rpx;
}

.es-section-label {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--text-secondary);
  white-space: nowrap;
}

.es-result-item {
  min-width: 0;
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-primary);
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ===== 反馈 ===== */
.aa-feedback {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  border-radius: var(--radius-sm);
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.aa-feedback-pass {
  background: var(--bg-soft-green);
  border: 1rpx solid rgba(37, 132, 74, 0.24);
}

.aa-feedback-review {
  background: var(--bg-soft-orange);
  border: 1rpx solid rgba(185, 91, 18, 0.22);
}

.aa-feedback-main {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.aa-feedback-sub {
  font-size: 22rpx;
  line-height: 1.5;
  color: var(--text-secondary);
}

/* ===== 底部键盘区（普通流定位） ===== */
.aa-keyboard {
  flex: none;
  margin: 0 24rpx 18rpx;
  padding: 14rpx 18rpx calc(14rpx + env(safe-area-inset-bottom));
  border-radius: 20rpx;
  background: var(--bg-card);
  border: 1px solid var(--border-subtle);
  box-shadow: var(--shadow-floating);
}

.aa-keyboard .keypad-grid-base {
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.aa-keyboard .keypad-key-base {
  min-height: 64rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
}

.aa-keyboard .keypad {
  margin-bottom: 8rpx;
}

.aa-action-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.aa-action-row .btn-base {
  width: 100%;
  margin: 0;
}

.aa-action-row .btn-base:only-child {
  grid-column: 1 / -1;
}

/* ===== keypad light style ===== */
.keypad-key-light {
  grid-column: span 2;
  font-size: 26rpx;
  color: var(--text-secondary);
  background: #f8fafc;
  border: 1px solid var(--border-soft);
}

/* ===== session-head ===== */
.session-head {
  margin-bottom: 14rpx;
}

.session-title {
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.2;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  word-break: break-word;
}

.session-meta-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
}

.session-meta-card {
  min-height: 76rpx;
  padding: 10rpx 6rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  box-shadow: none;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  border: 1px solid var(--border-subtle);
}

.session-meta-label {
  font-size: 20rpx;
  color: var(--text-tertiary);
  margin-bottom: 0;
  white-space: nowrap;
}

.session-meta-value {
  max-width: 100%;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.2;
  color: var(--text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.session-progress-track {
  height: 8rpx;
  margin-top: 12rpx;
  border-radius: 999rpx;
  background: var(--border-subtle);
  overflow: hidden;
}

.session-progress-fill {
  height: 100%;
  border-radius: inherit;
  background: var(--gradient-primary);
  transition: width 180ms ease;
}

/* ===== 小屏适配 ===== */
@media (max-width: 360px) {
  .aa-node {
    padding: 10rpx 10rpx;
    gap: 4rpx;
  }

  .aa-node-label {
    font-size: 20rpx;
    min-width: 28rpx;
  }

  .aa-node-value {
    font-size: 24rpx;
    padding: 4rpx 6rpx;
  }

  .aa-pill-value {
    font-size: 28rpx;
  }

}

/* ===== question-board ===== */
.question-board {
  padding: 28rpx 28rpx 26rpx;
  margin-bottom: 12rpx;
}

/* ===== 手写板入口 ===== */
.pen-entry {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--color-primary-500);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-sm);
  background: var(--bg-soft-blue);
  border: 1rpx solid var(--border-soft);
  white-space: nowrap;
}

/* ===== 手写板覆盖层 ===== */
.handwriting-overlay {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: stretch;
  justify-content: center;
  background: rgba(17, 24, 39, 0.42);
}

.handwriting-sheet {
  width: 100%;
  min-height: 0;
  height: 100%;
  padding: 88rpx 20rpx 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: transparent;
  box-shadow: none;
  display: flex;
  flex-direction: column;
}

.handwriting-canvas {
  flex: 1;
  min-height: 0;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.12);
  border: 1px solid rgba(255, 255, 255, 0.28);
}

.handwriting-toolbar {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 16rpx;
  padding: 12rpx;
  background: rgba(255, 255, 255, 0.22);
  backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg);
}

.handwriting-tool {
  min-height: 84rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.18);
  border: 1px solid rgba(255, 255, 255, 0.24);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
}

.handwriting-tool-active {
  color: #ffffff;
  background: linear-gradient(180deg, #6e7bff 0%, #5b63ff 100%);
  border-color: transparent;
}

.handwriting-tool-danger {
  background: linear-gradient(180deg, #ff8d7a 0%, #ff6a57 100%);
}

 .handwriting-tool-primary {
   color: #ffffff;
   background: var(--gradient-primary);
   border-color: transparent;
 }

 .question-top {
   display: flex;
   align-items: center;
   justify-content: space-between;
   gap: 16rpx;
   margin-bottom: 20rpx;
 }

 .question-no {
   font-size: 24rpx;
   font-weight: 700;
   color: var(--color-primary-500);
 }
