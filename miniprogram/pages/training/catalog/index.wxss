.catalog-page {
  min-height: 100vh;
  background: var(--bg-page-accent);
}

.catalog-shell {
  padding: 18rpx 24rpx 36rpx;
}

.catalog-hero {
  position: sticky;
  top: 0;
  z-index: 5;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  margin: -18rpx -24rpx 14rpx;
  padding: 18rpx 24rpx 14rpx;
  background: var(--bg-page-accent);
}

.catalog-hero-copy {
  flex: 1;
  min-width: 0;
}

.catalog-hero-title {
  font-size: 60rpx;
  line-height: 1.1;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 14rpx;
}

.catalog-hero-desc {
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.catalog-hero-underline {
  width: 52rpx;
  height: auto;
}

.catalog-hero-art {
  flex: none;
  width: 334rpx;
  height: 318rpx;
}

.catalog-hero-art-data-analysis,
.catalog-hero-art-cognition {
  width: 318rpx;
  height: 318rpx;
}

.catalog-count-wrap {
  margin-top: 0;
  margin-bottom: 0;
}

.catalog-count-tabs {
  width: 252rpx;
  padding: 8rpx 10rpx 8rpx 8rpx;
  gap: 0;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(47, 107, 255, 0.08);
  border-radius: 999rpx;
  box-shadow: var(--shadow-card);
}

.catalog-count-tab {
  flex: 1;
  min-width: 0;
  height: 62rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-secondary);
}

.catalog-count-tab-active {
  background: var(--gradient-primary);
  color: var(--text-on-primary);
  box-shadow: var(--shadow-active);
}

.catalog-group {
  margin-bottom: 16rpx;
}

.catalog-group-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 14rpx;
}

.catalog-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.catalog-grid-wide {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.catalog-item {
  min-height: 132rpx;
  padding: 16rpx 14rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  transition: transform 160ms ease, box-shadow 160ms ease, background 160ms ease;
}

.catalog-item-active {
  background: var(--gradient-primary);
  border-color: transparent;
  box-shadow: var(--shadow-floating);
}

.catalog-item-icon {
  width: 48rpx;
  height: 48rpx;
  flex: none;
  border-radius: 12rpx;
}

.catalog-item-title {
  font-size: 26rpx;
  font-weight: 500;
  line-height: 1.34;
  color: var(--text-primary);
  word-break: keep-all;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 4rpx;
  min-width: 0;
  flex: 1;
}

.catalog-item-title-line {
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.catalog-item-title-note {
  font-size: 18rpx;
  line-height: 1.3;
  white-space: normal;
}

.catalog-item-disabled {
  opacity: 0.7;
}

.catalog-item-status {
  font-size: 18rpx;
  line-height: 1.3;
  color: #b7791f;
}

.catalog-item-active .catalog-item-status {
  color: rgba(255, 255, 255, 0.88);
}

.catalog-item-active .catalog-item-title {
  color: var(--text-on-primary);
}

.catalog-bottom-safe {
  height: 142rpx;
}

.catalog-cta {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  display: flex;
  justify-content: center;
}

.catalog-cta-button {
  width: 100%;
  min-height: 96rpx;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 700;
}
