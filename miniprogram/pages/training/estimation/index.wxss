/* ===== 页面基础 ===== */
.page-fill {
  padding-bottom: 48rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

/* ===== 已知条件 ===== */
.es-conditions {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  background: #ffffff;
  border: 1rpx solid rgba(47, 107, 255, 0.18);
  border-radius: var(--radius-sm);
  overflow: hidden;
}

.es-condition-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx 0;
}

.es-condition-divider {
  width: 1rpx;
  align-self: stretch;
  background: var(--border-subtle);
}

.es-condition-label {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.es-condition-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

/* ===== 提示 ===== */
.es-hint {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 20rpx;
}

/* ===== 滑块区域 ===== */
.es-slider-area {
  position: relative;
  width: 100%;
  height: 160rpx;
  margin-bottom: 16rpx;
}

.es-slider-track {
  position: relative;
  width: 100%;
  height: 100%;
  border-radius: var(--radius-md);
  overflow: hidden;
  display: flex;
}

.es-slider-left {
  flex: none;
  height: 100%;
  background: linear-gradient(180deg, #4a86ff 0%, #2f6bff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: width 0.05s linear;
}

.es-slider-right {
  flex: 1;
  height: 100%;
  background: linear-gradient(180deg, #33c47a 0%, #22a865 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: width 0.05s linear;
}

.es-slider-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.15);
}

/* ===== 分界线手柄 ===== */
.es-slider-handle {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 50%;
  width: 40rpx;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.es-handle-bar {
  width: 40rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.es-handle-dot {
  width: 4rpx;
  height: 24rpx;
  border-radius: 2rpx;
  background: #c5c5c5;
}

/* ===== 实时预览 ===== */
.es-preview {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.es-preview-item {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.es-preview-divider {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-tertiary);
}

/* ===== 结果区域 ===== */
.es-result-section,
.es-reference-section {
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  border-radius: var(--radius-sm);
  background: var(--bg-soft-blue);
  border: 1rpx solid var(--border-soft);
}

.es-reference-section {
  background: var(--bg-soft-green);
  border: 1rpx solid rgba(37, 132, 74, 0.24);
}

.es-tone-pass {
  background: var(--bg-soft-green);
  border: 1rpx solid rgba(37, 132, 74, 0.24);
}

.es-tone-fail {
  background: var(--bg-soft-orange);
  border: 1rpx solid rgba(185, 91, 18, 0.22);
}

.es-section-label {
  display: block;
  font-size: 22rpx;
  font-weight: 700;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
}

.es-compact-result-row {
  display: grid;
  grid-template-columns: 112rpx minmax(0, 1fr) minmax(0, 1fr);
  align-items: center;
  gap: 12rpx;
}

.es-compact-result-row .es-section-label {
  margin-bottom: 0;
  white-space: nowrap;
}

.es-result-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  gap: 16rpx;
}

.es-result-item {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-primary);
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ===== 准确度 ===== */
.es-accuracy-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  padding: 0 8rpx;
}

.es-accuracy-label {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-secondary);
}

.es-accuracy-value {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--color-green-700);
}

.es-accuracy-bars {
  display: flex;
  gap: 8rpx;
  margin-top: 10rpx;
  padding: 0 8rpx;
}

.es-accuracy-bar {
  flex: 1;
  height: 12rpx;
  border-radius: 6rpx;
  transition: background 0.3s;
}

.es-accuracy-bar-on {
  background: var(--color-green-500);
}

.es-accuracy-bar-off {
  background: var(--border-subtle);
}

.es-accuracy-pass {
  color: var(--color-green-700);
}

.es-accuracy-fail {
  color: var(--color-orange-700);
}

.es-accuracy-bar-pass {
  background: var(--color-green-500);
}

.es-accuracy-bar-fail {
  background: var(--color-warning);
}

/* ===== 底部操作区 —— 与分配树对齐 ===== */
.answer-panel {
  padding: 16rpx;
  margin-bottom: 20rpx;
  margin-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.94);
  border: 1px solid var(--border-subtle);
  box-shadow: var(--shadow-floating);
}

.aa-action-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.aa-action-row .btn-base {
  width: 100%;
  margin: 0;
}

.aa-action-row .btn-base:only-child {
  grid-column: 1 / -1;
}

/* ===== 反馈区 —— 与分配树对齐 ===== */
.aa-feedback {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  border-radius: var(--radius-sm);
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.aa-feedback-pass {
  background: var(--bg-soft-green);
  border: 1rpx solid rgba(37, 132, 74, 0.24);
}

.aa-feedback-review {
  background: var(--bg-soft-orange);
  border: 1rpx solid rgba(185, 91, 18, 0.22);
}

.aa-feedback-main {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--text-primary);
}

/* ===== session-head ===== */
.session-head {
  margin-bottom: 14rpx;
}

.session-title {
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.2;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  word-break: break-word;
}

.session-meta-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
}

.session-meta-card {
  min-height: 76rpx;
  padding: 10rpx 6rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  box-shadow: none;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  border: 1px solid var(--border-subtle);
}

.session-meta-label {
  font-size: 20rpx;
  color: var(--text-tertiary);
  margin-bottom: 0;
  white-space: nowrap;
}

.session-meta-value {
  max-width: 100%;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.2;
  color: var(--text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.session-progress-track {
  height: 8rpx;
  margin-top: 12rpx;
  border-radius: 999rpx;
  background: var(--border-subtle);
  overflow: hidden;
}

.session-progress-fill {
  height: 100%;
  border-radius: inherit;
  background: var(--gradient-primary);
  transition: width 180ms ease;
}

/* ===== question-board ===== */
.question-board {
  padding: 28rpx 28rpx 26rpx;
  margin-bottom: 14rpx;
}

/* ===== 手写板入口 ===== */
.pen-entry {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--color-primary-500);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-sm);
  background: var(--bg-soft-blue);
  border: 1rpx solid var(--border-soft);
  white-space: nowrap;
  text-align: center;
  margin-bottom: 12rpx;
}

/* ===== 手写板覆盖层 ===== */
.handwriting-overlay {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: stretch;
  justify-content: center;
  background: rgba(17, 24, 39, 0.42);
}

.handwriting-sheet {
  width: 100%;
  min-height: 0;
  height: 100%;
  padding: 88rpx 20rpx 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: transparent;
  box-shadow: none;
  display: flex;
  flex-direction: column;
}

.handwriting-canvas {
  flex: 1;
  min-height: 0;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.12);
  border: 1px solid rgba(255, 255, 255, 0.28);
}

.handwriting-toolbar {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 16rpx;
  padding: 12rpx;
  background: rgba(255, 255, 255, 0.22);
  backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg);
}

.handwriting-tool {
  min-height: 84rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.18);
  border: 1px solid rgba(255, 255, 255, 0.24);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
}

.handwriting-tool-active {
  color: #ffffff;
  background: linear-gradient(180deg, #6e7bff 0%, #5b63ff 100%);
  border-color: transparent;
}

.handwriting-tool-danger {
  background: linear-gradient(180deg, #ff8d7a 0%, #ff6a57 100%);
}

 .handwriting-tool-primary {
   color: #ffffff;
   background: var(--gradient-primary);
   border-color: transparent;
 }

 .question-top {
   display: flex;
   align-items: center;
   justify-content: space-between;
   gap: 16rpx;
   margin-bottom: 20rpx;
 }

 .question-no {
   font-size: 24rpx;
   font-weight: 700;
   color: var(--color-primary-500);
 }
