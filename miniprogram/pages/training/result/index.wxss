.page-shell {
  min-height: 100vh;
  padding: 0 24rpx 180rpx;
  background: var(--bg-page-accent);
}

.hero-title {
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1.2;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.hero-subtitle {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-secondary);
}

.hero-meta {
  font-size: var(--font-caption);
  color: var(--text-secondary);
  margin-top: 12rpx;
}

.hero-level {
  font-weight: 700;
  color: var(--color-primary-500);
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.summary-card {
  padding: 22rpx 20rpx;
  text-align: center;
}

.summary-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-bottom: 8rpx;
}

.summary-value {
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.15;
  color: var(--text-primary);
}

.summary-value-warn {
  color: var(--color-danger);
}

.result-stats {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
}

.result-stats-item {
  min-width: 0;
}

.result-stats-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-bottom: 8rpx;
}

.result-stats-value {
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 700;
  color: var(--text-primary);
}

.records-card {
  overflow: hidden;
  margin-bottom: 8rpx;
}

.table-head {
  grid-template-columns: minmax(0, 2.3fr) minmax(0, 1.25fr) minmax(0, 1.1fr) 76rpx;
}

.record-row {
  grid-template-columns: minmax(0, 2.3fr) minmax(0, 1.25fr) minmax(0, 1.1fr) 76rpx;
  align-items: start;
}

.col-question {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  min-width: 0;
}

.record-index {
  width: 32rpx;
  font-size: 28rpx;
  color: var(--text-tertiary);
  flex: none;
}

.record-prompt,
.record-answer,
.record-user {
  font-size: 26rpx;
  font-weight: 700;
}

.record-prompt {
  color: var(--text-primary);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.45;
}

.record-formula {
  min-width: 0;
  padding: 4rpx 0;
  font-size: 24rpx;
  line-height: 1.3;
}

.record-formula .formula,
.record-compare-value .formula {
  justify-content: flex-start;
  align-items: flex-start;
  flex-wrap: wrap;
  row-gap: 4rpx;
}

.record-compare {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding: 2rpx 0;
}

.record-compare-value {
  min-width: 0;
  font-size: 24rpx;
  line-height: 1.3;
}

.record-compare-mark {
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1;
  color: var(--color-primary-500);
}

.record-answer {
  color: var(--text-primary);
  align-self: center;
  min-width: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.35;
}

.table-head-answer {
  min-width: 0;
  white-space: nowrap;
}

.table-head-user {
  justify-self: end;
  min-width: 0;
  white-space: nowrap;
}

.table-head-time {
  white-space: nowrap;
}

.record-user {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  align-self: center;
  gap: 4rpx;
  min-width: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.35;
}

.record-user-correct {
  color: var(--color-success);
}

.record-user-wrong {
  color: var(--color-danger);
}

.record-time {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--text-tertiary);
  text-align: right;
  align-self: center;
  line-height: 1.35;
}

.action-row {
  gap: 24rpx;
}

.action-row .btn-base {
  width: 100%;
}

.action-dock {
  padding: 16rpx;
}

.modal-actions {
  gap: 24rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.modal-actions .btn-base {
  min-height: 84rpx;
  font-size: 30rpx;
  width: 100%;
  padding: 0 10rpx;
}
