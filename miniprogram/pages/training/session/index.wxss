.page-shell {
  padding-bottom: 36rpx;
}

.session-head {
  margin-bottom: 14rpx;
}

.session-title {
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.2;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.session-meta-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
}

.session-meta-card {
  min-height: 64rpx;
  padding: 10rpx 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  box-shadow: none;
}

.session-meta-label {
  font-size: 20rpx;
  color: var(--text-tertiary);
  margin-bottom: 0;
  white-space: nowrap;
}

.session-meta-value {
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.2;
  color: var(--text-primary);
  white-space: nowrap;
}

.session-progress-track {
  height: 8rpx;
  margin-top: 12rpx;
  border-radius: 999rpx;
  background: var(--border-subtle);
  overflow: hidden;
}

.session-progress-fill {
  height: 100%;
  border-radius: inherit;
  background: var(--gradient-primary);
  transition: width 180ms ease;
}

.status-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.status-text {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-secondary);
}

.question-board {
  min-height: 340rpx;
  padding: 28rpx 28rpx 26rpx;
  margin-bottom: 14rpx;
}

.question-no {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--color-primary-500);
}

.question-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.pen-entry {
  min-width: 124rpx;
  height: 56rpx;
  padding: 0 20rpx;
  border-radius: 32rpx;
  background: var(--bg-soft-blue);
  border: 1px solid var(--border-subtle);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--color-primary-500);
}

.question-placeholder {
  font-size: 36rpx;
  line-height: 1.6;
  text-align: center;
  color: var(--text-secondary);
  padding: 80rpx 20rpx 0;
}

.question-prompt {
  font-size: 56rpx;
  font-weight: 600;
  line-height: 1.32;
  color: var(--text-primary);
  text-align: center;
  margin: 24rpx 0 16rpx;
}

.question-formula {
  font-size: 56rpx;
  font-weight: 600;
  line-height: 1.32;
  color: var(--text-primary);
  margin: 22rpx 0 16rpx;
  text-align: center;
}

.question-context {
  font-size: 28rpx;
  line-height: 1.55;
  text-align: center;
  color: var(--text-primary);
  margin-bottom: 10rpx;
}

.question-rule {
  font-size: 24rpx;
  line-height: 1.5;
  text-align: center;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.chart-board {
  margin-bottom: 24rpx;
}

.chart-grid {
  display: grid;
  grid-template-columns: 92rpx minmax(0, 1fr);
  gap: 12rpx;
  align-items: stretch;
}

.chart-y-axis {
  min-height: 360rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding-bottom: 44rpx;
}

.chart-y-tick {
  font-size: 22rpx;
  line-height: 1;
  color: var(--text-tertiary);
}

.chart-main {
  position: relative;
  min-height: 360rpx;
}

.chart-guides {
  position: absolute;
  inset: 0 0 44rpx 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.chart-guide-line {
  border-top: 2rpx solid rgba(47, 107, 255, 0.12);
}

.chart-bars {
  position: relative;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 12rpx;
  min-height: 360rpx;
  padding-top: 12rpx;
}

.chart-bar-col {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.chart-value {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
}

.chart-bar-wrap {
  width: 100%;
  min-height: 260rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.chart-bar {
  width: 44rpx;
  border-radius: 8rpx 8rpx 0 0;
  background: var(--gradient-primary);
}

.chart-label {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 10rpx;
}

.chart-legend {
  font-size: 24rpx;
  color: var(--color-primary-500);
  text-align: center;
  margin-top: 12rpx;
}

.compare-board {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  align-items: stretch;
  margin: 28rpx 0 16rpx;
}

.compare-value {
  font-size: 42rpx;
  font-weight: 500;
  line-height: 1.35;
  color: var(--text-primary);
  text-align: center;
  word-break: break-word;
  display: flex;
  justify-content: center;
  padding: 22rpx 20rpx;
  border-radius: 20rpx;
  background: var(--bg-soft-blue);
  min-height: 132rpx;
  align-items: center;
}

.compare-value math-formula {
  max-width: 100%;
}

.compare-mark {
  font-size: 52rpx;
  font-weight: 700;
  color: var(--color-primary-500);
  text-align: center;
  line-height: 1;
}

.compare-mark-gt {
  color: #2d8f62;
}

.compare-mark-lt {
  color: #7454d8;
}

.keypad {
  margin-bottom: 20rpx;
}

.compare-actions {
  margin-bottom: 24rpx;
  padding: 16rpx;
  border-radius: var(--radius-lg);
  background: rgba(255, 255, 255, 0.94);
  border: 1px solid var(--border-subtle);
  box-shadow: var(--shadow-floating);
}

.compare-choice-row {
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.compare-choice {
  min-height: 96rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 700;
  border: 1px solid transparent;
  opacity: 0.84;
}

.compare-choice-gt {
  color: #2d8f62;
  background: linear-gradient(180deg, #edf9f2 0%, #def4e7 100%);
  border-color: rgba(51, 196, 122, 0.2);
}

.compare-choice-lt {
  color: #7454d8;
  background: linear-gradient(180deg, #f3efff 0%, #ebe3ff 100%);
  border-color: rgba(124, 92, 255, 0.18);
}

.compare-choice-active {
  opacity: 1;
  box-shadow: var(--shadow-active);
}

.compare-choice-active-gt {
  color: #ffffff;
  background: linear-gradient(180deg, #55c98b 0%, #33c47a 100%);
  border-color: transparent;
}

.compare-choice-active-lt {
  color: #ffffff;
  background: linear-gradient(180deg, #9077ff 0%, #7c5cff 100%);
  border-color: transparent;
}

.compare-submit {
  width: 100%;
  min-height: 92rpx;
}

.answer-panel {
  padding: 16rpx;
  margin-bottom: 20rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1px solid var(--border-subtle);
  box-shadow: var(--shadow-floating);
}

.answer-submit {
  width: 100%;
  min-height: 92rpx;
}

.keypad-key-pressed,
.compare-choice-pressed,
.btn-pressed {
  transform: scale(0.97);
  opacity: 0.82;
}

.keypad-key-light {
  font-size: 26rpx;
}

.handwriting-overlay {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: stretch;
  justify-content: center;
  background: rgba(0, 0, 0, 0.3);
}

.handwriting-sheet {
  width: 100%;
  min-height: 0;
  height: 100%;
  padding: 88rpx 20rpx 24rpx;
  background: transparent;
  box-shadow: none;
}

.handwriting-canvas {
  flex: 1;
  min-height: 0;
  height: calc(100% - 132rpx);
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.handwriting-toolbar {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 16rpx;
  padding: 12rpx;
  background: rgba(255, 255, 255, 0.18);
  backdrop-filter: blur(20rpx);
}

.handwriting-tool {
  min-height: 84rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.14);
  border: 1px solid rgba(255, 255, 255, 0.16);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
}

.handwriting-tool-active {
  color: #ffffff;
  background: linear-gradient(180deg, #6e7bff 0%, #5b63ff 100%);
  border-color: transparent;
}

.handwriting-tool-danger {
  background: linear-gradient(180deg, #ff8d7a 0%, #ff6a57 100%);
}

.handwriting-tool-primary {
  color: #ffffff;
  background: var(--gradient-primary);
  border-color: transparent;
}
