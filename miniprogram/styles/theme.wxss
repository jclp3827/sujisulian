page {
  --bg-page: #f0f5fc;
  --bg-page-accent: linear-gradient(180deg, #f0f5fc 0%, #f0f5fc 100%);
  --bg-card: #ffffff;
  --bg-soft-blue: #f3f7ff;
  --bg-soft-green: #f1fbf6;
  --bg-soft-purple: #f5f2ff;
  --color-primary-500: #2f6bff;
  --color-primary-400: #4a86ff;
  --color-primary-100: #e8f0ff;
  --color-primary-50: #f3f7ff;
  --gradient-primary: linear-gradient(180deg, #4a86ff 0%, #2f6bff 100%);
  --color-green-500: #33c47a;
  --color-purple-500: #7c5cff;
  --text-primary: #111827;
  --text-secondary: #4b5563;
  --text-tertiary: #9ca3af;
  --text-disabled: #d1d5db;
  --text-on-primary: #ffffff;
  --border-subtle: #eef2f7;
  --border-soft: rgba(47, 107, 255, 0.08);
  --overlay-soft: rgba(17, 24, 39, 0.08);
  --shadow-card: 0 8rpx 24rpx rgba(47, 107, 255, 0.06);
  --shadow-floating: 0 16rpx 40rpx rgba(47, 107, 255, 0.12);
  --shadow-cta: 0 10rpx 30rpx rgba(47, 107, 255, 0.18);
  --shadow-active: 0 10rpx 24rpx rgba(47, 107, 255, 0.1);
  --radius-xs: 8rpx;
  --radius-sm: 12rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --space-1: 8rpx;
  --space-2: 12rpx;
  --space-3: 16rpx;
  --space-4: 24rpx;
  --space-5: 32rpx;
  --space-6: 40rpx;
  --space-7: 48rpx;
  --space-8: 64rpx;
  --font-caption: 24rpx;
  --font-body: 28rpx;
  --font-subtitle: 32rpx;
  --font-title: 44rpx;
  --font-display: 72rpx;
  --font-heading: 34rpx;

  /* Backward-compatible aliases */
  --color-bg-start: #f0f5fc;
  --color-bg-end: #f0f5fc;
  --color-surface: rgba(255, 255, 255, 0.82);
  --color-surface-strong: rgba(255, 255, 255, 0.96);
  --color-surface-muted: rgba(47, 107, 255, 0.06);
  --color-card-start: #ffffff;
  --color-card-end: #fdfefe;
  --color-primary: var(--color-primary-500);
  --color-primary-soft: var(--color-primary-400);
  --color-primary-pale: var(--color-primary-50);
  --color-text: var(--text-primary);
  --color-text-strong: var(--text-primary);
  --color-text-muted: var(--text-secondary);
  --color-text-subtle: var(--text-tertiary);
  --color-line: rgba(156, 163, 175, 0.2);
  --color-line-soft: rgba(156, 163, 175, 0.12);
  --color-success: var(--color-green-500);
  --color-warning: #f59a23;
  --color-danger: #ff4d4f;
  --space-xs: var(--space-2);
  --space-sm: var(--space-3);
  --space-md: var(--space-4);
  --space-lg: var(--space-5);
  --space-xl: var(--space-7);
}
