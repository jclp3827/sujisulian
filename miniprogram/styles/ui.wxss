.surface-card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  border: 1px solid var(--border-subtle);
  box-shadow: var(--shadow-card);
}

.surface-panel {
  border-radius: var(--radius-md);
  background: var(--bg-soft-blue);
}

.floating-bar {
  border-radius: var(--radius-lg);
  background: rgba(255, 255, 255, 0.94);
  box-shadow: var(--shadow-floating);
}

.floating-bar-fixed {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  padding: 16rpx;
}

.pill-action {
  flex: none;
  min-height: 56rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(47, 107, 255, 0.12);
  box-shadow: var(--shadow-card);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 700;
  color: var(--color-primary-500);
  white-space: nowrap;
}

.note-search-entry {
  width: 112rpx;
  min-width: 112rpx;
  min-height: 58rpx;
  padding: 0 22rpx;
  justify-content: center;
  background: var(--bg-card);
  color: var(--color-primary-500);
}

.tap-arrow {
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  border-radius: 999rpx;
  background: var(--bg-soft-blue);
  color: var(--text-tertiary);
  font-size: 34rpx;
  line-height: 1;
  font-weight: 500;
}

.segmented-control {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx;
  border-radius: 999rpx;
  background: var(--bg-soft-blue);
}

.page-pad {
  padding: 24rpx;
}

.page-pad-wide {
  padding: 48rpx 24rpx 80rpx;
}

.page-fill {
  min-height: 100vh;
}

.hero-block {
  padding: 48rpx 32rpx 32rpx;
  text-align: center;
}

.hero-block-tight {
  padding: 40rpx 0 16rpx;
}

.page-title-center {
  font-size: var(--font-title);
  font-weight: 600;
  color: var(--text-primary);
  text-align: center;
}

.section-title-marker {
  font-size: var(--font-body);
  font-weight: 700;
  color: var(--text-primary);
}

.data-table-head,
.data-table-row {
  display: grid;
  column-gap: 12rpx;
  align-items: center;
  padding: 20rpx 32rpx;
}

.data-table-head {
  font-size: var(--font-body);
  font-weight: 700;
  color: #313131;
  border-top: 1px solid var(--color-line);
  border-bottom: 1px solid var(--color-line);
}

.data-table-row {
  border-bottom: 1px solid var(--color-line-soft);
}

.nav-entry-card {
  padding: 12rpx 0;
  margin-bottom: 24rpx;
}

.nav-entry-main {
  min-height: 148rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-entry-copy {
  flex: 1;
  padding-right: 24rpx;
}

.nav-entry-name {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-text-strong);
  margin-bottom: 16rpx;
}

.nav-entry-desc {
  font-size: var(--font-caption);
  line-height: 1.5;
  color: var(--color-text-subtle);
}

.nav-entry-arrow {
  flex: none;
  font-size: 54rpx;
  color: var(--text-tertiary);
}

.modal-overlay {
  position: fixed;
  inset: 0;
  background: var(--overlay-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
}

.modal-surface {
  width: 100%;
  border-radius: var(--radius-xl);
  background: var(--bg-card);
  padding: 48rpx 28rpx 28rpx;
}

.modal-title {
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.25;
  color: var(--text-primary);
  text-align: center;
  margin-bottom: 24rpx;
}

.modal-copy {
  font-size: 28rpx;
  line-height: 1.7;
  color: var(--text-secondary);
  text-align: center;
  margin-bottom: 20rpx;
}

.modal-level {
  font-size: var(--font-body);
  font-weight: 700;
  line-height: 1.5;
  color: var(--color-primary-500);
  text-align: center;
  margin-bottom: 36rpx;
}

.keypad-grid-base {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.keypad-key-base {
  min-height: 96rpx;
  border-radius: var(--radius-sm);
  background: var(--bg-card);
  border: 1px solid var(--border-subtle);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.answer-display {
  min-height: 92rpx;
  border-radius: var(--radius-sm);
  background: rgba(255, 255, 255, 0.75);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
  font-size: 40rpx;
  font-weight: 600;
  color: #333333;
}

.dual-action-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  align-items: stretch;
  column-gap: 20rpx;
  row-gap: 20rpx;
}

.dual-action-grid .btn-base {
  width: 100%;
  min-width: 0;
  padding: 0 12rpx;
  box-sizing: border-box;
}

.sheet-drawer {
  width: 100%;
  min-height: 50vh;
  background: rgba(255, 255, 255, 0.98);
  border-top-left-radius: var(--radius-xl);
  border-top-right-radius: var(--radius-xl);
  padding: 24rpx 24rpx 40rpx;
}

.sheet-drawer-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.sheet-drawer-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.sheet-drawer-actions {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.sheet-drawer-action {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
}

.sheet-drawer-note {
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.sheet-drawer-canvas {
  width: 100%;
  height: 420rpx;
  border-radius: var(--radius-sm);
  background: var(--bg-soft-blue);
  border: 2rpx solid var(--border-subtle);
}

.btn-base {
  min-height: 96rpx;
  padding: 0 24rpx;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.2;
  white-space: nowrap;
  text-align: center;
  box-sizing: border-box;
}

.btn-pressed {
  transform: scale(0.97);
  opacity: 0.82;
}

.btn-large {
  min-height: 96rpx;
  font-size: 34rpx;
}

.btn-primary {
  background: var(--gradient-primary);
  color: var(--text-on-primary);
  box-shadow: var(--shadow-cta);
}

.btn-secondary {
  background: var(--bg-card);
  color: var(--text-primary);
  border: 1px solid var(--border-subtle);
}

.btn-ghost {
  background: var(--bg-soft-blue);
  color: var(--text-primary);
}

.btn-confirm {
  background: var(--color-primary-400);
  color: var(--text-on-primary);
}

.title-display {
  font-size: var(--font-display);
  font-weight: 500;
  color: var(--text-primary);
}

.title-page {
  font-size: var(--font-title);
  font-weight: 700;
  color: var(--text-primary);
}

.text-body {
  font-size: var(--font-body);
  color: var(--text-secondary);
}

.text-caption {
  font-size: var(--font-caption);
  color: var(--text-tertiary);
}
