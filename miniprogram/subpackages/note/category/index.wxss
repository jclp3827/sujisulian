.note-category-page {
  min-height: 100vh;
  background: var(--bg-page-accent);
}

.note-category-shell {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
}

.note-category-hero {
  padding: 4rpx 2rpx 26rpx;
}

.note-category-kicker {
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 700;
  color: var(--color-green-500);
  margin-bottom: 8rpx;
}

.note-category-title-row {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.note-category-title {
  flex: 0 1 auto;
  display: inline-block;
  width: auto;
  min-width: 0;
  max-width: calc(100% - 180rpx);
  font-size: 46rpx;
  line-height: 1.2;
  font-weight: 700;
  color: var(--text-primary);
}

.note-category-desc {
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--text-secondary);
}

.note-category-chip {
  flex: none;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: var(--bg-soft-blue);
  color: var(--color-primary-500);
  font-size: 22rpx;
  line-height: 1.25;
  font-weight: 700;
}

.note-point-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.note-point-card {
  padding: 24rpx 22rpx;
}

.note-point-main {
  min-width: 0;
}

.note-point-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.note-point-title-row {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 12rpx;
  flex-wrap: wrap;
}

.note-point-type {
  flex: none;
  max-width: 104rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(47, 107, 255, 0.08);
  font-size: 22rpx;
  line-height: 1.25;
  font-weight: 700;
  color: rgba(47, 107, 255, 0.8);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.note-point-title {
  flex: 0 1 auto;
  display: inline-block;
  width: auto;
  min-width: 0;
  max-width: calc(100% - 128rpx);
  font-size: 34rpx;
  line-height: 1.25;
  font-weight: 700;
  color: var(--text-primary);
}

.note-point-arrow {
  background: var(--bg-soft-blue);
}

.note-point-formula {
  overflow-x: auto;
  min-height: 72rpx;
  padding: 18rpx 20rpx;
  border-radius: var(--radius-sm);
  background: var(--bg-soft-blue);
  font-size: 26rpx;
  line-height: 1.5;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 14rpx;
  display: flex;
  align-items: center;
}

.note-point-formula .formula {
  justify-content: flex-start;
}

.note-point-preview-text {
  display: block;
  width: 100%;
  line-height: 1.45;
  text-align: left;
  word-break: break-word;
}

.note-point-scene {
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--text-secondary);
  word-break: break-word;
}
