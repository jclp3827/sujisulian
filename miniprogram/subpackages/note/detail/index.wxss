.note-detail-page {
  min-height: 100vh;
  background: var(--bg-page-accent);
}

.note-detail-shell {
  min-height: 100vh;
  padding: 24rpx 24rpx 56rpx;
}

.note-detail-hero {
  padding: 4rpx 2rpx 26rpx;
}

.note-detail-kicker {
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 700;
  color: var(--color-green-500);
  margin-bottom: 8rpx;
}

.note-detail-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.note-detail-title {
  flex: 1;
  min-width: 0;
  font-size: 48rpx;
  line-height: 1.18;
  font-weight: 700;
  color: var(--text-primary);
}

.note-detail-training-action {
  flex: none;
  max-width: 260rpx;
  min-width: 0;
  min-height: 58rpx;
  padding: 0 22rpx;
  border-radius: var(--radius-sm);
  font-size: 24rpx;
  line-height: 1.2;
  background: transparent;
  color: var(--color-primary-500);
  border: 2rpx solid var(--color-primary-500);
  box-shadow: none;
}

.note-detail-desc {
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--text-secondary);
}

.note-detail-tabs-scroll {
  width: 100%;
  margin-bottom: 20rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.note-detail-tabs {
  display: inline-flex;
  width: auto;
  max-width: none;
  box-sizing: border-box;
  vertical-align: top;
  overflow-x: visible;
  white-space: nowrap;
  background: rgba(47, 107, 255, 0.1);
  border: 1rpx solid rgba(47, 107, 255, 0.1);
}

.note-detail-tab {
  flex: 0 0 auto;
  min-width: 104rpx;
  min-height: 54rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  color: var(--text-secondary);
  white-space: nowrap;
}

.note-detail-tab-active {
  background: #ffffff;
  color: var(--color-primary-500);
  box-shadow: 0 8rpx 20rpx rgba(47, 107, 255, 0.14);
}

.note-detail-section {
  padding: 28rpx 24rpx;
}

.note-block {
  position: relative;
  margin-bottom: 28rpx;
  padding-bottom: 28rpx;
  border-bottom: 1rpx solid rgba(156, 163, 175, 0.14);
}

.note-block:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: 0;
}

.note-block-emphasis,
.note-block-grouped,
.note-block-wide,
.note-example-block {
  margin-left: -2rpx;
  margin-right: -2rpx;
}

.note-section-label {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 700;
  color: var(--text-primary);
  margin: 2rpx 0 14rpx;
}

.note-section-label::before {
  content: "";
  width: 8rpx;
  height: 24rpx;
  border-radius: 999rpx;
  background: var(--color-primary-500);
}

.note-formula-box {
  overflow-x: auto;
  padding: 22rpx;
  border-radius: var(--radius-sm);
  background: linear-gradient(180deg, #f6f9ff 0%, #edf4ff 100%);
  border: 1rpx solid rgba(47, 107, 255, 0.12);
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 700;
  color: var(--text-primary);
}

.note-formula-box .formula {
  justify-content: flex-start;
}

.formula-box-formula {
  margin-bottom: 32rpx;
}

.formula-box-formula:last-child {
  margin-bottom: 0;
}

.note-formula-desc {
  margin-top: 14rpx;
  padding: 0 4rpx;
  font-size: 24rpx;
  line-height: 1.55;
  color: var(--text-secondary);
  text-align: left;
}

.note-step-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.note-step-item {
  display: grid;
  grid-template-columns: 44rpx minmax(0, 1fr);
  column-gap: 14rpx;
  align-items: start;
  padding: 14rpx 16rpx;
  border-radius: var(--radius-sm);
  background: var(--bg-soft-blue);
}

.note-step-index {
  width: 44rpx;
  height: 44rpx;
  border-radius: 999rpx;
  background: var(--color-primary-100);
  color: var(--color-primary-500);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
}

.note-step-text,
.note-tip-text,
.note-example-stem,
.note-example-analysis,
.note-practice-desc,
.note-check-text,
.note-compare-content,
.note-compare-item,
.note-table-cell {
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--text-secondary);
  word-break: break-word;
}

.note-plain-list {
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  gap: 12rpx;
}

.note-plain-item {
  min-height: 58rpx;
  border-radius: var(--radius-sm);
  background: var(--bg-soft-blue);
  display: flex;
  align-items: flex-start;
  padding: 10rpx 16rpx;
  font-size: 25rpx;
  line-height: 1.35;
  font-weight: 700;
  color: var(--text-primary);
  word-break: break-word;
}

.note-check-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.note-check-item {
  display: grid;
  grid-template-columns: 18rpx minmax(0, 1fr);
  column-gap: 14rpx;
  align-items: start;
  padding: 16rpx 18rpx;
  border-radius: var(--radius-sm);
  background: #f8fbff;
  border: 1rpx solid rgba(47, 107, 255, 0.08);
}

.note-check-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: var(--color-primary-500);
  margin-top: 16rpx;
}

.note-compare-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  gap: 14rpx;
}

.note-compare-card {
  min-width: 0;
  padding: 20rpx;
  border-radius: var(--radius-sm);
  background: var(--bg-soft-blue);
  border: 1rpx solid rgba(47, 107, 255, 0.08);
}

.note-compare-card-accent {
  background: var(--bg-soft-green);
}

.note-compare-title {
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 10rpx;
}

.note-compare-content {
  font-weight: 700;
  color: var(--text-primary);
}

.note-compare-item {
  margin-top: 8rpx;
}

.note-table {
  overflow-x: auto;
  border-radius: var(--radius-sm);
  background: var(--bg-soft-blue);
  border: 1rpx solid rgba(76, 112, 146, 0.12);
}

.note-table-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  border-top: 2rpx solid rgba(76, 112, 146, 0.12);
}

.note-table-row:first-child {
  border-top: 0;
}

.note-table-head {
  background: rgba(255, 255, 255, 0.62);
}

.note-table-head .note-table-cell {
  font-weight: 700;
  color: var(--text-primary);
}

.note-table-cell {
  min-width: 0;
  padding: 16rpx 18rpx;
  border-left: 2rpx solid rgba(76, 112, 146, 0.12);
  word-break: break-word;
}

.note-table-cell:first-child {
  border-left: 0;
}

.note-table-cell-index,
.note-table-cell-term {
  white-space: nowrap;
  word-break: keep-all;
}

.note-table-cell-index {
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.note-table-cell-term {
  text-align: left;
}

.note-table-cell-content,
.note-table-cell-accent {
  text-align: left;
}

.note-table-cell-accent {
  color: var(--text-primary);
  background: var(--bg-soft-green);
  border-color: rgba(51, 196, 122, 0.12);
  font-weight: 700;
}

.note-table-compact .note-table-cell {
  padding: 12rpx 10rpx;
  font-size: 23rpx;
  line-height: 1.35;
  text-align: center;
}

.note-table-compact .note-table-cell-term,
.note-table-compact .note-table-cell-content,
.note-table-compact .note-table-cell-accent {
  text-align: left;
}

.note-mind-map {
  padding: 20rpx;
  overflow: hidden;
  border-radius: var(--radius-sm);
  background: linear-gradient(180deg, #f8fbff 0%, #f3f7f2 100%);
}

.note-mind-root {
  padding: 22rpx;
  border-radius: var(--radius-sm);
  background: #ffffff;
  border: 2rpx solid rgba(47, 107, 255, 0.14);
}

.note-mind-root-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  flex-wrap: wrap;
}


.note-mind-root-title {
  flex: 1;
  min-width: 0;
  font-size: 34rpx;
  line-height: 1.35;
  font-weight: 800;
  color: var(--text-primary);
}

.note-mind-root-summary {
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.55;
  color: var(--text-secondary);
}

.note-mind-toggle-all {
  min-height: 48rpx;
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(47, 107, 255, 0.08);
  font-size: 23rpx;
  line-height: 1.35;
  color: var(--color-primary-600);
}

.note-mind-branches {
  margin-top: 22rpx;
}

.note-mind-branch {
  position: relative;
  padding-left: 20rpx;
  margin-top: 20rpx;
  border-left: 4rpx solid rgba(47, 107, 255, 0.22);
}

.note-mind-branch:first-child {
  margin-top: 0;
}

.note-mind-node {
  position: relative;
  padding: 18rpx 20rpx;
  border-radius: var(--radius-sm);
  background: #ffffff;
  border: 2rpx solid rgba(76, 112, 146, 0.12);
}

.note-mind-node::before {
  content: "";
  position: absolute;
  left: -34rpx;
  top: 28rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: var(--color-primary-500);
}

.note-mind-node-level-1 {
  background: #ffffff;
}

.note-mind-node-level-2 {
  background: #f8fafc;
}

.note-mind-node-level-3 {
  background: #fffdf7;
}

.note-mind-node-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.note-mind-node-toggleable {
  cursor: pointer;
}

.note-mind-node-title {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  line-height: 1.35;
  font-weight: 800;
  color: var(--text-primary);
}

.note-mind-toggle {
  flex-shrink: 0;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(76, 112, 146, 0.1);
  font-size: 22rpx;
  line-height: 1.35;
  color: var(--text-secondary);
}

.note-mind-node-summary {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--text-secondary);
}

.note-mind-point-list {
  margin-top: 12rpx;
}

.note-mind-point {
  position: relative;
  padding-left: 20rpx;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--text-secondary);
}

.note-mind-point::before {
  content: "";
  position: absolute;
  left: 0;
  top: 15rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--color-green-500);
}

.note-mind-children {
  margin-top: 14rpx;
  padding-left: 18rpx;
  border-left: 2rpx solid rgba(76, 112, 146, 0.16);
}

.note-mind-children-deep {
  border-left-style: dashed;
}

.note-mind-child {
  margin-top: 14rpx;
}

.note-mind-child:first-child {
  margin-top: 0;
}

.note-mind-image-wrap {
  overflow: hidden;
  margin-top: 16rpx;
  border-radius: var(--radius-sm);
  background: #ffffff;
  border: 2rpx solid rgba(76, 112, 146, 0.12);
}

.note-mind-image-title {
  padding: 14rpx 16rpx 0;
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 700;
  color: var(--text-primary);
}

.note-mind-image {
  display: block;
  width: 100%;
  margin-top: 12rpx;
}

.note-mind-image-desc {
  padding: 12rpx 16rpx 16rpx;
  font-size: 22rpx;
  line-height: 1.45;
  color: var(--text-muted);
}

.note-image-note {
  overflow: hidden;
  border-radius: var(--radius-sm);
  background: var(--bg-soft-blue);
  border: 1rpx solid rgba(76, 112, 146, 0.12);
}

.note-image {
  display: block;
  width: 100%;
}

.note-image-placeholder {
  min-height: 240rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 28rpx;
  border: 2rpx dashed rgba(47, 107, 255, 0.22);
  border-radius: var(--radius-sm);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.7) 0%, rgba(243, 247, 255, 0.88) 100%);
}

.note-image-title {
  max-width: 100%;
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  text-align: center;
  word-break: break-word;
}

.note-image-status {
  max-width: 100%;
  min-width: 104rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: var(--bg-card);
  font-size: 22rpx;
  line-height: 1.25;
  font-weight: 700;
  color: var(--color-primary-500);
  text-align: center;
  white-space: normal;
}

.note-image-desc {
  padding: 18rpx 20rpx;
  font-size: 25rpx;
  line-height: 1.55;
  color: var(--text-secondary);
  word-break: break-word;
}

.note-tip-box,
.note-warning-box {
  padding: 20rpx 22rpx;
  border-radius: var(--radius-sm);
}

.note-tip-box {
  background: var(--bg-soft-green);
  border: 1rpx solid rgba(51, 196, 122, 0.12);
}

.note-warning-box {
  background: #fff7ed;
  border: 1rpx solid rgba(245, 154, 35, 0.14);
}

.note-tip-title {
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.note-example-stem {
  padding: 22rpx;
  border-radius: var(--radius-sm);
  background: var(--bg-soft-blue);
  border: 1rpx solid rgba(47, 107, 255, 0.08);
  margin-bottom: 20rpx;
}

.note-example-analysis {
  padding: 22rpx;
  border-radius: var(--radius-sm);
  background: var(--bg-soft-green);
  border: 1rpx solid rgba(51, 196, 122, 0.12);
}

.note-example-image-note {
  overflow: hidden;
  margin-top: 16rpx;
  border-radius: var(--radius-sm);
  background: var(--bg-soft-blue);
}

.note-example-source {
  display: inline-block;
  align-self: flex-start;
  padding: 6rpx 16rpx;
  margin-bottom: 12rpx;
  border-radius: 999rpx;
  background: var(--bg-card);
  color: var(--color-green-500);
  font-size: 22rpx;
  line-height: 1.3;
  font-weight: 700;
  box-shadow: var(--shadow-active);
}

.note-example-options {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.note-example-option {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 14rpx 16rpx;
  border-radius: var(--radius-sm);
  background: #f8fbff;
  border: 1rpx solid rgba(47, 107, 255, 0.08);
  font-size: 26rpx;
  line-height: 1.55;
  color: var(--text-primary);
}

.note-example-option-key {
  flex-shrink: 0;
  min-width: 36rpx;
  height: 36rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-card);
  color: var(--color-green-500);
  font-size: 24rpx;
  font-weight: 700;
  box-shadow: var(--shadow-active);
}

.note-example-option-text {
  flex: 1;
  min-width: 0;
  word-break: break-word;
}

.note-example-option-answer {
  background: var(--bg-soft-green);
}

.note-example-option-answer .note-example-option-key {
  background: var(--color-green-500);
  color: var(--text-inverse);
}

.note-example-answer-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
  padding: 12rpx 16rpx;
  border-radius: var(--radius-sm);
  background: var(--bg-soft-green);
  border: 1rpx solid rgba(51, 196, 122, 0.14);
}

.note-example-answer-label {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--color-green-500);
}

.note-example-answer-value {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.note-practice-title {
  font-size: 36rpx;
  line-height: 1.25;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.note-load-more {
  margin-top: 24rpx;
  padding: 22rpx;
  text-align: center;
  border-radius: var(--radius-sm);
  background: #f8fbff;
  border: 1rpx solid rgba(47, 107, 255, 0.1);
}

.note-load-more-text {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--color-primary-500);
}
