.note-map-page {
  min-height: 100vh;
  background: var(--bg-page-accent);
}

.note-map-shell {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
}

.note-map-hero {
  padding: 4rpx 2rpx 28rpx;
}

.note-map-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.note-map-search {
  flex: none;
}

.note-map-kicker {
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 700;
  color: var(--color-green-500);
  margin-bottom: 8rpx;
}

.note-map-title {
  flex: 1;
  min-width: 0;
  font-size: 48rpx;
  line-height: 1.18;
  font-weight: 700;
  color: var(--text-primary);
}

.note-map-desc {
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--text-secondary);
}

.note-map-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.note-map-chip {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: var(--bg-soft-green);
  color: var(--color-green-500);
  font-size: 22rpx;
  line-height: 1.25;
  font-weight: 700;
}

.note-map-chip-soft {
  background: var(--bg-soft-blue);
  color: var(--color-primary-500);
}

.note-path {
  display: flex;
  flex-direction: column;
}

.note-path-item {
  min-height: 148rpx;
}

.note-path-card {
  min-height: 132rpx;
  padding: 22rpx 18rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.note-path-index {
  flex: none;
  width: 52rpx;
  height: 52rpx;
  border-radius: 999rpx;
  background: var(--bg-soft-blue);
  border: 2rpx solid var(--border-subtle);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 23rpx;
  line-height: 1;
  font-weight: 800;
  color: var(--text-tertiary);
}

.note-path-index-ready {
  background: var(--bg-soft-green);
  border-color: rgba(51, 196, 122, 0.18);
  color: var(--color-green-500);
}

.note-path-card-ready {
  border-color: rgba(51, 196, 122, 0.16);
}

.note-path-card-pending {
  opacity: 0.72;
}

.note-path-main {
  flex: 1;
  min-width: 0;
}

.note-path-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
  margin-bottom: 8rpx;
}

.note-path-title-row {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: flex-end;
  justify-content: flex-start;
  gap: 12rpx;
  flex-wrap: wrap;
}

.note-path-title {
  flex: 0 1 auto;
  min-width: 0;
  max-width: 100%;
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 700;
  color: var(--text-primary);
  word-break: normal;
  overflow-wrap: normal;
}

.note-path-count {
  flex: none;
  max-width: 180rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(47, 107, 255, 0.08);
  color: rgba(47, 107, 255, 0.8);
  font-size: 22rpx;
  line-height: 1.25;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.note-path-status {
  flex: none;
  min-width: 90rpx;
  padding: 7rpx 12rpx;
  border-radius: 999rpx;
  background: var(--bg-soft-blue);
  color: var(--text-tertiary);
  font-size: 21rpx;
  line-height: 1.2;
  text-align: center;
}

.note-status-ready {
  background: var(--bg-soft-green);
  color: var(--color-green-500);
}

.note-path-subtitle {
  font-size: 24rpx;
  line-height: 1.45;
  color: var(--text-secondary);
  margin-bottom: 6rpx;
  word-break: break-word;
}

.note-path-arrow {
  background: var(--bg-soft-blue);
}
