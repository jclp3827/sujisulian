.note-search-page {
  min-height: 100vh;
  background: var(--bg-page-accent);
}

.note-search-shell {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
}

.note-search-hero {
  padding: 26rpx 24rpx;
  margin-bottom: 18rpx;
}

.note-search-hero-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.note-search-kicker {
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 700;
  color: var(--color-green-500);
  margin-bottom: 8rpx;
}

.note-search-title {
  max-width: 440rpx;
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 700;
  color: var(--text-primary);
}

.note-search-clear {
  min-width: 96rpx;
}

.note-search-bar {
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #fff;
  border: 1rpx solid rgba(47, 107, 255, 0.12);
}

.note-search-input {
  width: 100%;
  font-size: 28rpx;
  line-height: 1.4;
  color: var(--text-primary);
}

.note-search-scope {
  display: inline-flex;
  max-width: 100%;
  margin-top: 14rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: var(--bg-soft-blue);
  font-size: 22rpx;
  line-height: 1.25;
  color: var(--color-primary-500);
  font-weight: 700;
}

.note-search-summary {
  font-size: 24rpx;
  line-height: 1.35;
  color: var(--text-secondary);
  margin: 0 0 14rpx 4rpx;
}

.note-search-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.note-search-card {
  padding: 22rpx 20rpx;
}

.note-search-card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.note-search-card-title {
  flex: 1;
  min-width: 0;
  font-size: 32rpx;
  line-height: 1.3;
  font-weight: 700;
  color: var(--text-primary);
}

.note-search-card-tag {
  flex: none;
  max-width: 176rpx;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(47, 107, 255, 0.08);
  color: rgba(47, 107, 255, 0.8);
  font-size: 20rpx;
  line-height: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.note-search-path {
  display: inline-flex;
  max-width: 100%;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: var(--bg-soft-green);
  color: var(--color-green-500);
  font-size: 21rpx;
  line-height: 1.25;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.note-search-match {
  display: inline-flex;
  max-width: 100%;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(47, 107, 255, 0.08);
  font-size: 22rpx;
  line-height: 1.25;
  font-weight: 700;
  color: rgba(47, 107, 255, 0.8);
  margin-bottom: 10rpx;
}

.note-search-more {
  padding: 22rpx;
  text-align: center;
  border-radius: var(--radius-sm);
  background: #f8fbff;
  border: 1rpx solid rgba(47, 107, 255, 0.1);
}

.note-search-more-text {
  font-size: 26rpx;
  line-height: 1.35;
  font-weight: 700;
  color: rgba(47, 107, 255, 0.8);
}

.note-search-desc {
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.note-search-preview {
  padding-top: 8rpx;
  border-top: 1rpx solid rgba(156, 163, 175, 0.12);
  font-size: 22rpx;
  line-height: 1.45;
  color: var(--text-tertiary);
}

.note-search-empty {
  padding: 44rpx 28rpx;
  text-align: center;
}

.note-search-empty-title {
  font-size: 30rpx;
  line-height: 1.4;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 10rpx;
}

.note-search-empty-desc {
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--text-secondary);
}
